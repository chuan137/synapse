{
  "hooks": {
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "synapse hook guard"
          }
        ],
        "matcher": ".*"
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "synapse hook event PreToolUse"
          }
        ],
        "matcher": ".*"
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .synapse/synapse-hook.sh"
          }
        ],
        "matcher": ""
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "synapse hook event PostToolUse"
          }
        ],
        "matcher": ""
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "synapse hook event UserPromptSubmit"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "synapse hook event SubagentStart"
          }
        ],
        "matcher": ".*"
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "synapse hook event SubagentStop"
          }
        ],
        "matcher": ".*"
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "synapse hook event PreCompact"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "synapse hook event SessionStart"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "synapse hook event SessionEnd"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "synapse hook event Stop"
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "synapse hook event Notification"
          }
        ]
      }
    ]
  }
}