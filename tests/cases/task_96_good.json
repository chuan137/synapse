    "id": 96,
    "agent_id": "cec50b17:35",
    "title": "Unify task workflow: start_task always first, delegate_task only sends message",
    "status": "completed",
    "started_at": 1780914466104,
    "finished_at": 1780914569138,
    "trigger_msg_id": 1339,
